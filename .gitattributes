# Auto-handle merge conflicts for generated leaderboard files.
# These are always regenerated by `stellcoilbench update-db`, so on conflict
# we prefer the remote (incoming) version — git pull overwrites local.
#
# REQUIRED: run once after cloning to register the "theirs" merge driver:
#   git config merge.theirs.driver 'cat %B > %A'
# Note: docs/leaderboard/*.rst and docs/leaderboards/*.md are gitignored
# (generated at build time). docs/leaderboard.json is also gitignored;
# only leaderboard.rst is tracked for CI.
docs/leaderboard.rst merge=theirs

# LFS for submissions/ large files (VTK, plots).
# Uses dedicated repo akaptano/stellcoilbench-lfs — forks cannot push (no write access).
# See docs/forking.md for fork owners who want to add submissions.
submissions/**/*.vtu filter=lfs diff=lfs merge=lfs -text
submissions/**/*.vts filter=lfs diff=lfs merge=lfs -text
submissions/**/*.png filter=lfs diff=lfs merge=lfs -text
submissions/**/*.pdf filter=lfs diff=lfs merge=lfs -text
# LFS for cases/done/ (autopilot results; same patterns as submissions + large JSON).
cases/done/**/*.vtu filter=lfs diff=lfs merge=lfs -text
cases/done/**/*.vts filter=lfs diff=lfs merge=lfs -text
cases/done/**/*.png filter=lfs diff=lfs merge=lfs -text
cases/done/**/*.pdf filter=lfs diff=lfs merge=lfs -text
cases/done/**/*.json filter=lfs diff=lfs merge=lfs -text
