# Git LFS configuration. Points to a dedicated repo that only upstream has write access.
# Forks can PULL (read) but cannot PUSH — they get 403. To add submissions from a fork,
# add .lfsconfig in your fork pointing to your own LFS backend. See docs/forking.md.
# url: HTTPS for fetch (anonymous on public repo; CI clones work without LFS_DEPLOY_KEY).
# pushurl: SSH for push (requires LFS_DEPLOY_KEY; ci_setup_lfs_ssh.sh configures github-lfs host).
[lfs]
	url = https://github.com/akaptano/stellcoilbench-lfs.git/info/lfs
	pushurl = git@github-lfs:akaptano/stellcoilbench-lfs.git
